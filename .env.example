# ============================================================
# MFT — 환경 변수 템플릿 (.env.example)
# ============================================================
# 로컬 개발: 이 파일을 복사해 .env로 저장 후 실제 값으로 채움
# Vercel 배포: 같은 키들을 Vercel Project Settings → Environment Variables에 등록
# ============================================================

# ----- Supabase Postgres -----
# Supabase Dashboard → Project Settings → Database → Connection string (URI 모드)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres"
# Direct connection (migrations / shadow DB용)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres"

# ----- LLM API 키 (Phase 1 head-to-head 평가 후 한쪽만 사용) -----
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# ----- Admin 인증 -----
# bcrypt hash. 생성: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=""
# JWT 서명 secret (32+ chars). 생성: openssl rand -base64 32
ADMIN_JWT_SECRET=""

# ----- 운영 알림 -----
# Discord 채널 webhook URL (운영자 전용)
DISCORD_WEBHOOK_URL=""

# ----- IG 크롤러 -----
# 일반 브라우저 UA 1개 고정. 차단되면 archive-only fallback 진입.
IG_FETCH_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# ----- Next.js -----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
