datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// v7: Human-in-the-loop 검수 파이프라인. ingest로 들어온 모든 신규 row는 PENDING으로
// 시작하고, /admin/review에서 운영자가 승인/편집/거절. 사이트의 public 쿼리는
// status = APPROVED만 노출. ReviewLog는 편집·승인 이력을 누적해 학습 신호로 사용.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Artist {
  id            String   @id @default(cuid())
  canonicalName String
  canonicalKey  String   @unique
  aliases       String[]
  igHandle      String?  @unique
  firstSeenAt   DateTime @default(now())
  shows         Show[]   @relation("ShowArtists")

  // External catalog enrichment (Spotify primary)
  spotifyId        String?  @unique
  spotifyImageUrl  String?  // raw Spotify CDN URL (for reference / re-download)
  imageUrl         String?  // Supabase Storage URL (display)
  genres           String[]
  popularity       Int?     // 0-100 (Spotify popularity)
  followerCount    Int?
  bioText          String?  @db.Text
  externalLinks    Json?    // { spotify, apple, youtube, bandcamp, official, ... }
  lastEnrichedAt   DateTime?

  tracks           Track[]
  enrichCandidates SpotifyMatchCandidate[]

  @@index([spotifyId])
  @@index([popularity])
}

// Catalog tracks pulled from Spotify per artist (renamed from "Song" because
// the Song model is already used for setlist entries — different concept).
// Many-to-one Artist for now; collaborations would need a join table -- V2.
model Track {
  id              String    @id @default(cuid())
  title           String
  artistId        String
  artist          Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  durationMs      Int?
  releaseDate     DateTime? @db.Date
  isrc            String?   @unique
  spotifyId       String?   @unique
  previewUrl      String?
  albumName       String?
  albumImageUrl   String?   // Supabase Storage URL (display)
  albumImageRaw   String?   // raw Spotify CDN URL
  popularity      Int?
  trackNumber     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([artistId])
  @@index([releaseDate])
}

// Audit trail for the artist matching pass — store candidate hits per artist
// so the operator can review/override which Spotify ID got chosen.
model SpotifyMatchCandidate {
  id          String   @id @default(cuid())
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  rank        Int      // 1 = top candidate
  spotifyId   String
  spotifyName String
  popularity  Int?
  genres      String[]
  imageUrl    String?
  score       Float    // matching confidence 0..1
  reason      String   // "exact_korean" | "alias_match" | "fuzzy" | "manual" ...
  createdAt   DateTime @default(now())

  @@index([artistId, rank])
}

model Venue {
  id           String     @id @default(cuid())
  name         String
  canonicalKey String     @unique
  address      String?
  region       String?
  lat          Float?
  lng          Float?
  shows        Show[]
  festivals    Festival[]
}

model VenueAlias {
  id           String @id @default(cuid())
  canonicalKey String
  alias        String @unique
  addedBy      String // 'operator' | 'auto'

  @@index([canonicalKey])
}

model Festival {
  id             String    @id @default(cuid())
  name           String
  canonicalKey   String    @unique
  aliases        String[]
  startDate      DateTime? @db.Date // v5: nullable (Model A 일관성 — partial 게시물 허용)
  endDate        DateTime? @db.Date // v5: nullable
  venueId        String?
  venue          Venue?    @relation(fields: [venueId], references: [id])
  locationText   String?
  officialUrl    String?
  ticketUrl      String?
  ticketOpenAt   DateTime? // 예매 오픈 일시 (페스티벌 통합 예매 — 내부 show가 상속)
  igHandle       String?   @unique
  posterImageUrl String?
  description    String?
  shows          Show[]
  infoPosts      FestivalInfo[]
  // v5: completeness 모델 일관 적용
  completeness   Int       @default(0) // 0~2 (name·startDate · ≥1 Show)
  needsReview    Boolean   @default(true) // legacy 필드, status로 점진 대체 중
  // v7: human-in-the-loop status. 사이트의 public 쿼리는 APPROVED만 노출.
  status         ReviewStatus @default(PENDING)
  reviewedAt     DateTime?
  reviewedBy     String?   // admin user id
  reviewerNote   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([startDate, endDate])
  @@index([completeness])
  @@index([status])
}

// v5: 합병 이력 추적 (Critic MAJOR — AC-5b 보강).
// v5.1 retention 정책: append-only. V1 scale (≤500 merges/year 추정)에서 cleanup 불필요.
// row count >10k에 도달하면 V2에 archive·prune ADR 추가.
model ShowMergeLog {
  id       String   @id @default(cuid())
  winnerId String // 살아남은 Show
  loserData Json    // 패자 Show 스냅샷 (artist ids, fingerprint, dates 등)
  mergedAt DateTime @default(now())
  mergedBy String   // 'operator' | 'crawler-auto'
  reason   String?  // 'admin-edit-promotion' | 'crawler-fingerprint-conflict' | etc

  @@index([winnerId])
  @@index([mergedAt])
}

model Show {
  id                String    @id @default(cuid())
  // v6: per-performance times moved to ShowSession. Legacy columns retained
  // (deprecated, populated by ingest for back-compat until read paths migrate).
  date              DateTime? @db.Date /// DEPRECATED — use sessions[0].date / firstSessionDate
  startTime         String?            /// DEPRECATED — use sessions[0].startTime
  // v6: denormalized session date range for fast sort/filter without join.
  // Maintained by ingest and merge scripts.
  firstSessionDate  DateTime? @db.Date
  lastSessionDate   DateTime? @db.Date
  sessions          ShowSession[]
  venueId           String? // v4: nullable
  venue             Venue?    @relation(fields: [venueId], references: [id])
  artists           Artist[]  @relation("ShowArtists") // v4: 0개여도 OK
  title             String?
  originalPostUrl   String    @unique // v4: 자연 키 (1 IG post → 1 Show)
  // v6 deprecated — ticketUrl moved to ShowSession (per-day open/url differs).
  // Kept as fallback display when sessions are empty/legacy.
  ticketUrl         String?
  imageUrl          String?
  rawTextExcerpt    String?   @db.Text
  festivalId        String?
  festival          Festival? @relation(fields: [festivalId], references: [id])
  stage             String?
  setOrder          Int?
  setlist           Setlist?
  // v4: completeness 모델
  completeness      Int       @default(0) // 0~3 (date·venue·artists≥1)
  missingFields     String[]              // ['date'|'venue'|'artists'] 부분집합
  needsReview       Boolean   @default(true) // legacy 필드, status로 점진 대체 중
  // v7: human-in-the-loop status. 사이트의 public 쿼리는 APPROVED만 노출.
  status            ReviewStatus @default(PENDING)
  reviewedAt        DateTime?
  reviewedBy        String?   // admin user id
  reviewerNote      String?
  fingerprint       String?   @unique // v4: nullable, completeness=3에 도달하면 생성
  fingerprintInputs Json? // v4: nullable
  duplicateOfShowId String?              // v5: 크롤러 dup 감지 시 winner 가리킴, admin 확인 대기
  duplicateOf       Show?     @relation("DuplicateOf", fields: [duplicateOfShowId], references: [id]) // v5.1 self-ref FK
  duplicates        Show[]    @relation("DuplicateOf")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([date])
  @@index([firstSessionDate])                          // v6: 새 정렬 인덱스
  @@index([festivalId])
  @@index([completeness, date]) // v4: 검색 랭킹·관리자 큐 정렬용
  @@index([completeness, firstSessionDate])            // v6: 같은 용도, sessions 기반
  @@index([duplicateOfShowId]) // v5.1: '중복 후보' 탭 쿼리
  @@index([status])
  @@index([status, firstSessionDate])
}

/// v6: Each calendar performance of a named Show.
/// Multi-day or multi-session shows produce N rows; single-day shows produce 1.
model ShowSession {
  id           String    @id @default(cuid())
  showId       String
  show         Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  date         DateTime  @db.Date
  startTime    String?   // "HH:MM" 24h
  endTime      String?   // "HH:MM" 24h, optional
  ticketUrl     String?   // 일자별 예매 페이지가 다를 수 있어 session-level
  ticketOpenAt  DateTime? // 일자별 오픈 시각이 다를 수 있어 session-level (일반 예매 오픈)
  presaleOpenAt DateTime? // 선예매(카드사 등) 오픈 시각. 일반 예매(ticketOpenAt)보다 앞섬
  capacity     Int?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([showId, date]) // 같은 Show + 같은 일자 = 같은 Session (idempotent upsert)
  @@index([date])
  @@index([showId])
}

model Setlist {
  id          String   @id @default(cuid())
  showId      String   @unique
  show        Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  sourceNotes String?
  songs       Song[]
  updatedAt   DateTime @updatedAt
}

model Song {
  id        String  @id @default(cuid())
  setlistId String
  setlist   Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  isEncore  Boolean @default(false)
  coverOf   String?

  @@index([setlistId, order])
}

model InstagramPost {
  canonicalUrl        String   @id
  sourceAccount       String
  postedAt            DateTime
  rawText             String   @db.Text
  imageUrls           String[]
  postType            String   // 'single_show' | 'festival_lineup' | 'setlist' | 'unrelated'
  extractedShowId     String?
  extractedFestivalId String?
  fetchedAt           DateTime @default(now())

  @@index([sourceAccount, postedAt])
}

model SeedAccount {
  igHandle         String    @id // canonical
  kind             String    // 'festival' | 'artist' | 'venue'
  status           String    // 'pending' | 'active' | 'dead' | 'rejected'
  addedBy          String    // 'operator' | 'snowball'
  sourceSeedHandle String?   // snowball provenance — references SeedAccount.igHandle
  addedAt          DateTime  @default(now())
  promotedAt       DateTime?
  lastFetched      DateTime?
  consecutiveFails Int       @default(0)
  removedAt        DateTime?

  @@index([status, lastFetched])
}

// v7: 운영자가 /admin/review에서 row를 편집·승인·거절할 때 한 행씩 누적.
// 학습 신호로 사용 — 누적된 row를 보고 스킬의 추출 규칙 보완 (CORRECTIONS.md).
model ReviewLog {
  id           String   @id @default(cuid())
  entityType   String   // 'Show' | 'Festival' | 'Artist' | 'Venue' | 'ShowSession'
  entityId     String
  field        String?  // null = 'whole row approve/reject'. 편집이면 'title' | 'sessions[0].startTime' | etc
  oldValue     Json?
  newValue     Json?
  action       String   // 'approve' | 'reject' | 'edit' | 'reopen'
  source       String   // 'ingest' | 'admin' | 'auto'
  ingestRunPath String? // 어느 .omc/ingest-log/{ts}.json 에서 들어왔는지 역참조
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}

// v8: 페스티벌 관람 정보(사이트맵·타임테이블·교통·규정·FAQ·MD/푸드·편의시설 등).
// IG 관람정보 게시물 1건 = FestivalInfo 1행. imageUrls는 캐러셀 슬라이드 N장.
// ingest가 PENDING으로 생성, /admin/review에서 카테고리 보정·승인. 공개는 APPROVED만.
enum FestivalInfoCategory {
  MAP        // 사이트맵 / 배치도 / 부스맵
  TIMETABLE  // 타임테이블 / 러닝오더
  ACCESS     // 교통 / 주차 / 셔틀
  RULES      // 반입금지 / 입장 / 유의사항
  FAQ        // 자주 묻는 질문
  GOODS      // MD/굿즈 판매, 푸드트럭·F&B 라인업
  AMENITY    // 편의시설 / 물품보관 / 우천대비
  TICKET     // 티켓 오픈·예매처·가격·얼리버드·블라인드·매진·현장판매·VIP/프리미엄 패스
  PROMO      // 파트너/스폰서 소개, 브랜드 콜라보, 경품·추첨·증정 이벤트, D-day/예고 공지
  NOTICE     // 기타 관람 공지
}

model FestivalInfo {
  id            String   @id @default(cuid())
  festivalId    String
  festival      Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  category      FestivalInfoCategory
  title         String?
  imageUrls     String[]            // 캐러셀 슬라이드 N장
  bodyText      String?  @db.Text
  sourcePostUrl String   @unique    // 1 IG post → 1 InfoPost (멱등 키)
  postedAt      DateTime?
  order         Int      @default(0)
  status        ReviewStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewerNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([festivalId, category])
  @@index([status])
}

model CrawlRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  status            String    // 'running' | 'success' | 'partial' | 'failed' | 'blocked_suspected'
  accountsAttempted Int       @default(0)
  accountsSucceeded Int       @default(0)
  postsFetched      Int       @default(0)
  postsClassified   Int       @default(0)
  showsCreated      Int       @default(0)
  showsUpdated      Int       @default(0)
  festivalsCreated  Int       @default(0)
  snowballAdded     Int       @default(0)
  llmTokensIn       Int       @default(0)
  llmTokensOut      Int       @default(0)
  llmCostCents      Int       @default(0)
  durationMs        Int?
  errors            Json?

  @@index([startedAt])
}

// v11: ingest 작업 대기열 관측. ingest-collect가 캡션 JSON을 수집하면 여기에 'collected'로
// 등록되고(finalize.mjs), ingest-show(scripts/ingest.ts)가 적재를 마치면 'loaded'로 도장찍힌다.
// /admin/ingest 가 이 테이블을 읽어 "처리 대기 / 적재 완료"를 보여준다. PK=igHandle:
// 같은 계정을 다시 수집하면 같은 행을 덮어쓰며 status가 'collected'로 되돌아간다(재처리 신호).
model IngestSource {
  igHandle    String   @id                       // canonical handle (full-<handle>.json)
  fullName    String?                             // IG 프로필 표시명
  kind        String?                             // 'artist' | 'festival' (null=미분류)
  status      String   @default("collected")      // 'collected'(대기) | 'loaded'(완료)
  fetched     Int      @default(0)                // 수집된 게시물 수
  mediaCount  Int?                                // 프로필이 신고한 총 게시물 수
  complete    Boolean?                            // fetched >= mediaCount-3 (완전 수집 여부)
  filePath    String?                             // /tmp/full-<handle>.json
  collectedAt DateTime @default(now())            // 마지막 수집 시각
  loadedAt    DateTime?                           // 마지막 적재 시각
  showsLoaded Int?                                // 적재 시 생성/갱신된 Show 수
  note        String?

  @@index([status])
  @@index([collectedAt])
}

// v12: 일반 사용자(페스티벌 관람객) 프로필. 인증 자체는 Supabase Auth가 auth.users에서
// 관리하고, public 스키마에는 표시용 프로필만 둔다. id = auth.users.id(uuid)를 그대로 PK로
// 재사용 → 첫 로그인 시 콜백에서 upsert(중복 생성 없음). 향후 업로드 글/사진이 이 id를 FK로 참조.
// admin(mft_admin 쿠키) 시스템과 완전히 분리된 별개 레이어.
model Profile {
  id            String    @id                  // = auth.users.id (Supabase Auth UUID)
  nickname      String?                         // 카카오 닉네임 (provider metadata)
  avatarUrl     String?                         // 카카오 프로필 이미지 URL
  // 약관·개인정보처리방침 동의 기록. 첫 로그인 후 /agree에서 동의하면 시각·버전을 남긴다.
  // agreedAt이 null이면 미동의 상태 → 가입 미완료로 보고 /agree로 유도.
  agreedAt      DateTime?                        // 약관 동의 시각 (null=미동의)
  agreedVersion String?                          // 동의한 약관 버전(예: '2026-06-14'). 약관 개정 시 재동의 유도용.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}
